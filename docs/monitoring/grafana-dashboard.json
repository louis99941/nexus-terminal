{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP 请求延迟 P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 延迟"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "活跃连接数",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "websocket_active_connections", "legendFormat": "WebSocket" },
        { "expr": "ssh_active_sessions", "legendFormat": "SSH 会话" },
        { "expr": "ssh_pool_connections", "legendFormat": "SSH 连接池" }
      ]
    },
    {
      "title": "SSH 连接耗时分布",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(ssh_connect_duration_seconds_bucket[5m])",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "title": "认证失败次数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(auth_failures_total[5m])",
          "legendFormat": "5 分钟失败数"
        }
      ]
    },
    {
      "title": "SFTP 传输速率",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(sftp_transferred_bytes_total[5m])",
          "legendFormat": "{{direction}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "title": "Node.js 内存使用",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "nodejs_heap_used_bytes", "legendFormat": "Heap Used" },
        { "expr": "nodejs_heap_total_bytes", "legendFormat": "Heap Total" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nexus-terminal", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Nexus Terminal 监控面板",
  "uid": "nexus-terminal-dashboard",
  "version": 1
}
