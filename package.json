{
  "name": "nexus-terminal",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "directories": {
    "doc": "doc"
  },
  "scripts": {
    "test": "npm run test:backend && npm run test:remote-gateway && npm run test:frontend",
    "test:backend": "npm run -w @nexus-terminal/backend test",
    "test:remote-gateway": "npm run -w @nexus-terminal/remote-gateway test",
    "test:frontend": "npm run -w @nexus-terminal/frontend test",
    "test:e2e": "npm run -w @nexus-terminal/frontend test:e2e",
    "test:e2e:ui": "npm run -w @nexus-terminal/frontend test:e2e:ui",
    "test:e2e:headed": "npm run -w @nexus-terminal/frontend test:e2e:headed",
    "test:watch:backend": "npm run -w @nexus-terminal/backend test:watch",
    "test:watch:remote-gateway": "npm run -w @nexus-terminal/remote-gateway test:watch",
    "test:watch:frontend": "npm run -w @nexus-terminal/frontend test:watch",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:remote-gateway && npm run test:coverage:frontend",
    "test:coverage:backend": "npm run -w @nexus-terminal/backend test:coverage",
    "test:coverage:remote-gateway": "npm run -w @nexus-terminal/remote-gateway test:coverage",
    "test:coverage:frontend": "npm run -w @nexus-terminal/frontend test:coverage",
    "test:perf": "npm run test:perf:backend",
    "test:perf:backend": "npm run -w @nexus-terminal/backend test:perf",
    "test:perf:watch": "npm run -w @nexus-terminal/backend test:perf:watch",
    "test:lighthouse": "npm run -w @nexus-terminal/frontend test:lighthouse",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "debt:check": "node scripts/check-tech-debt.js",
    "typecheck:frontend": "npm run -w @nexus-terminal/frontend -s typecheck",
    "typecheck:backend": "npx tsc -p packages/backend/tsconfig.json --noEmit",
    "typecheck:remote-gateway": "npx tsc -p packages/remote-gateway/tsconfig.json --noEmit",
    "quality:check": "npm run -s debt:check && npm run -s typecheck:frontend && npm run -s typecheck:backend && npm run -s typecheck:remote-gateway && npm run -s lint -- --max-warnings=0 && npm run -s format:check",
    "i18n:locales:check": "node scripts/sync-locales.js --check",
    "i18n:locales:sync": "node scripts/sync-locales.js --write",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,md}\"",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Silentely/nexus-terminal.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Silentely/nexus-terminal/issues"
  },
  "homepage": "https://github.com/Silentely/nexus-terminal#readme",
  "description": "",
  "dependencies": {
    "archiver-zip-encrypted": "^2.0.0",
    "axios": "^1.15.0",
    "element-plus": "^2.13.7",
    "fs-extra": "^11.3.0",
    "pinia-plugin-persistedstate": "^4.2.0",
    "vuedraggable": "^4.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.0",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "sqlite3": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.7"
  },
  "overrides": {
    "vite": "^6.4.2",
    "esbuild": "^0.25.0",
    "tar": ">=7.5.13",
    "cookie": "^0.7.2",
    "tmp": "^0.2.5",
    "fast-xml-parser": ">=5.3.8",
    "basic-ftp": ">=5.2.0",
    "rollup": ">=4.58.1",
    "path-to-regexp": "8.4.2",
    "defu": "^6.1.7",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "router": {
      "path-to-regexp": "8.4.2"
    },
    "editorconfig": ">=2.0.1",
    "vue": ">=3.0.0",
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.0",
    "@tootallnate/once": "^3.0.1",
    "glob": ">=10.4.6"
  }
}
